# ---- LLM (OpenAI) ----
# Leave OPENAI_API_KEY empty to run in deterministic MOCK MODE (no external calls).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# ---- Web research (Tavily) ----
# Leave empty to use mock search results.
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5

# ---- Database (PostgreSQL) ----
# SQLAlchemy uses the psycopg3 driver; the LangGraph checkpointer derives a
# plain psycopg DSN from this automatically.
DATABASE_URL=postgresql+psycopg://copilot:copilot@localhost:5432/copilot

# ---- Workflow tuning ----
QUALITY_THRESHOLD=0.7
MAX_RESEARCH_RETRIES=2

# ---- API ----
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]
LOG_LEVEL=INFO
